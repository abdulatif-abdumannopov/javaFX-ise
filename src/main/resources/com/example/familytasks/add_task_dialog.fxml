<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.familytasks.controllers.AddTaskController"
      prefWidth="300" style="-fx-padding: 20;">

    <Label text="Новое задание" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <TextField fx:id="titleField" promptText="Что нужно сделать?"/>
    <TextField fx:id="rewardField" promptText="Количество очков (напр. 200)"/>

    <ComboBox fx:id="childSelector" promptText="Выберите ребенка" maxWidth="Infinity"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Отмена" onAction="#handleCancel" styleClass="btn, btn-default"/>
        <Button text="Создать" onAction="#handleSave" styleClass="btn, btn-success"/>
    </HBox>
</VBox>