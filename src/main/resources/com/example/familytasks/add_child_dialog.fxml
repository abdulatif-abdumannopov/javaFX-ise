<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.familytasks.controllers.AddChildController"
      prefWidth="300" style="-fx-padding: 20;">

    <Label text="Новый профиль ребенка" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <VBox spacing="5">
        <Label text="Имя (Логин):"/>
        <TextField fx:id="nameField" promptText="Напр. Артем"/>
    </VBox>

    <VBox spacing="5">
        <Label text="Пароль для ребенка:"/>
        <PasswordField fx:id="passwordField" promptText="******"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Отмена" onAction="#handleCancel" styleClass="btn, btn-default"/>
        <Button text="Создать" onAction="#handleSave" styleClass="btn, btn-primary"/>
    </HBox>
</VBox>