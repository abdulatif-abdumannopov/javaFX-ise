<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.familytasks.controllers.ChildController"
            prefHeight="600.0" prefWidth="800.0">

    <top>
        <HBox spacing="20" alignment="CENTER_LEFT" style="-fx-background-color: #0984e3; -fx-padding: 15;">
            <Label text="Мои Задания" style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="10" alignment="CENTER">
                <Label text="Мои очки:" style="-fx-text-fill: white;"/>
                <Label fx:id="balanceLabel" text="0" style="-fx-text-fill: #fdcb6e; -fx-font-weight: bold; -fx-font-size: 18px;"/>
            </HBox>
            <Button text="Профиль" onAction="#handleShowProfile"
                    style="-fx-background-color: #1b1b20; -fx-text-fill: white;"
                    styleClass="btn"/>
            <Button text="История" onAction="#handleShowHistory" styleClass="btn, btn-info"/>
            <Button text="Выйти" onAction="#handleLogout" styleClass="btn, btn-sm, btn-danger"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 20;">
            <TableView fx:id="tasksTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colTitle" text="Что сделать" prefWidth="400"/>
                    <TableColumn fx:id="colReward" text="Награда" prefWidth="100"/>
                    <TableColumn fx:id="colStatus" text="Статус" prefWidth="150"/>
                </columns>
            </TableView>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="completeButton" text="Отправить на проверку"
                        onAction="#handleCompleteTask" styleClass="btn, btn-lg, btn-success" />
            </HBox>
        </VBox>
    </center>
</BorderPane>